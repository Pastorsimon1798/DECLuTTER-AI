# Database
DATABASE_URL=postgresql+asyncpg://postgres:devpass@localhost:5432/communitycircle
DATABASE_URL_SYNC=postgresql://postgres:devpass@localhost:5432/communitycircle

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_NAME=CommunityCircle
DEBUG=True
ENVIRONMENT=development
API_V1_PREFIX=/api

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (for Celery and caching)
REDIS_URL=redis://localhost:6379/0

# SMS (Plivo)
PLIVO_AUTH_ID=your-plivo-auth-id
PLIVO_AUTH_TOKEN=your-plivo-auth-token
PLIVO_PHONE_NUMBER=+15551234567

# Email (Brevo)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@communitycircle.org
BREVO_SENDER_NAME=CommunityCircle

# 211 API
TWO11_API_KEY=your-211-api-key
TWO11_API_URL=https://api.211.org

# Frontend URL (for SMS links, emails)
FRONTEND_URL=http://localhost:5173

# Monitoring
SENTRY_DSN=
POSTHOG_API_KEY=
