# MutualCircle Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ===== Database Configuration =====
DATABASE_URL=postgresql+asyncpg://postgres:devpass@localhost:5432/mutualcircle_dev
DATABASE_URL_SYNC=postgresql://postgres:devpass@localhost:5432/mutualcircle_dev
TEST_DATABASE_URL=postgresql+asyncpg://postgres:devpass@localhost:5432/mutualcircle_test

# ===== Security =====
# IMPORTANT: Change this to a long, random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Application Settings =====
APP_NAME=MutualCircle
DEBUG=True
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ===== CORS (Cross-Origin Resource Sharing) =====
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Redis (for Celery task queue and caching) =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===== Email Configuration (Brevo/SendGrid) =====
# Brevo (recommended for free tier)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@mutualcircle.org
BREVO_SENDER_NAME=MutualCircle

# Alternative: SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key
# SENDGRID_SENDER_EMAIL=noreply@mutualcircle.org

# Generic SMTP (if not using Brevo or SendGrid)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@mutualcircle.org
SMTP_FROM_NAME=MutualCircle

# ===== SMS Configuration (Plivo/Twilio) =====
# Plivo (more affordable)
PLIVO_AUTH_ID=your-plivo-auth-id
PLIVO_AUTH_TOKEN=your-plivo-auth-token
PLIVO_PHONE_NUMBER=+15551234567

# Alternative: Twilio
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+15551234567

# ===== External APIs =====
# 211 API for resource listings
TWO11_API_KEY=your-211-api-key
TWO11_API_URL=https://api.211.org

# Google Maps API (for geocoding and maps)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ===== Frontend URL =====
# Used for generating links in SMS and emails
FRONTEND_URL=http://localhost:5173

# ===== Error Tracking & Analytics (Optional) =====
# Sentry for error monitoring (production)
SENTRY_DSN=

# PostHog for analytics (optional)
POSTHOG_API_KEY=

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ===== Security Headers & Rate Limiting =====
RATE_LIMIT_ENABLED=True
MAX_REQUESTS_PER_MINUTE=100

# ===== File Upload Settings =====
MAX_UPLOAD_SIZE_MB=10
UPLOAD_FOLDER=/tmp/mutualcircle/uploads

# ===== Development Tools =====
# Enable API documentation endpoints (Swagger/ReDoc)
ENABLE_DOCS=True

# Enable development tools
DEV_MODE=True

# ===== Production Settings (Only in production .env) =====
# ENVIRONMENT=production
# DEBUG=False
# ALLOWED_ORIGINS=https://mutualcircle.org,https://www.mutualcircle.org
# FRONTEND_URL=https://mutualcircle.org
# ENABLE_DOCS=False
# DEV_MODE=False
