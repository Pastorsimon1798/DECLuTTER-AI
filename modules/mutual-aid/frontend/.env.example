# MutualCircle Frontend Environment Variables
# Copy this file to .env for development or .env.production for production

# ===== API Configuration =====
VITE_API_URL=http://localhost:8000/api/v1

# ===== Environment =====
VITE_ENV=development
VITE_APP_NAME=MutualCircle

# ===== Maps & Location =====
# Google Maps API key for resource maps and location features
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ===== Error Tracking (Optional) =====
# Sentry DSN for frontend error monitoring in production
VITE_SENTRY_DSN=

# ===== Analytics (Optional) =====
# PostHog for product analytics
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Google Analytics (optional)
VITE_GA_TRACKING_ID=

# ===== Feature Flags (Optional) =====
# Enable/disable features without code changes
VITE_ENABLE_POD_FEATURE=true
VITE_ENABLE_RESOURCE_MAPS=true
VITE_ENABLE_SMS_NOTIFICATIONS=true

# ===== Social Media Links =====
VITE_TWITTER_HANDLE=@mutualcircle
VITE_GITHUB_URL=https://github.com/yourusername/mutualcircle

# ===== Support Links =====
VITE_SUPPORT_EMAIL=support@mutualcircle.org
VITE_DOCS_URL=https://docs.mutualcircle.org

# ===== Production Settings (Use in .env.production) =====
# VITE_API_URL=https://api.mutualcircle.org/api/v1
# VITE_ENV=production
# VITE_ENABLE_SENTRY=true
