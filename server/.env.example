# DECLuTTER-AI backend environment template.
# Copy to .env locally or set these values in your host secret manager.

# Self-hosted MVP mode (recommended first on a VPS):
# DECLUTTER_AUTH_MODE=shared_token
# DECLUTTER_SHARED_ACCESS_TOKEN=replace-with-a-long-random-self-hosted-token
# DECLUTTER_STORAGE_BACKEND=local
# DECLUTTER_UPLOAD_DIR=/data/uploads
# DECLUTTER_SESSION_DB_PATH=/data/declutter_ai_sessions.sqlite3
#
# ---------------------------------------------------------------------------
# Vision analysis provider (provider-agnostic, model-agnostic)
# ---------------------------------------------------------------------------
# Supported providers:
#   mock           — deterministic mock detections (default, no API key needed)
#   openai         — OpenAI API (gpt-4o, gpt-4o-mini, etc.)
#   groq           — Groq Cloud (OpenAI-compatible, fast, cheap)
#   together       — Together.ai (OpenAI-compatible)
#   fireworks      — Fireworks AI (OpenAI-compatible)
#   cerebras       — Cerebras (OpenAI-compatible)
#   anthropic      — Anthropic Claude Messages API
#   claude         — alias for anthropic
#   lmstudio       — LM Studio local server (OpenAI-compatible wrapper)
#   ollama-native  — Ollama native /api/generate endpoint (not /v1 compatible)
#
# Any provider exposing an OpenAI-compatible /v1/chat/completions endpoint
# works automatically with the openai/groq/together/fireworks/cerebras/lmstudio
# aliases. Anthropic and Ollama-native have dedicated adapters.
#
# Common environment variables (all providers):
#   DECLUTTER_INFERENCE_BASE_URL    — API base URL
#   DECLUTTER_INFERENCE_MODEL       — Model name (e.g., gpt-4o-mini, llava, claude-3-5-sonnet)
#   DECLUTTER_INFERENCE_API_KEY     — API key / bearer token
#   DECLUTTER_INFERENCE_TIMEOUT_SECONDS — default 180
#   DECLUTTER_INFERENCE_MAX_TOKENS  — default 256
#
# Provider-specific fallbacks (optional):
#   OPENAI_BASE_URL / OPENAI_API_KEY / OPENAI_MODEL
#   LMSTUDIO_BASE_URL / LMSTUDIO_API_KEY / LMSTUDIO_MODEL
#   ANTHROPIC_BASE_URL / ANTHROPIC_API_KEY / ANTHROPIC_MODEL
#   OLLAMA_BASE_URL / OLLAMA_API_KEY / OLLAMA_MODEL
#
# Example: OpenAI GPT-4o mini
# DECLUTTER_ANALYSIS_PROVIDER=openai
# DECLUTTER_INFERENCE_BASE_URL=https://api.openai.com/v1
# DECLUTTER_INFERENCE_MODEL=gpt-4o-mini
# DECLUTTER_INFERENCE_API_KEY=sk-...
# DECLUTTER_INFERENCE_TIMEOUT_SECONDS=60
#
# Example: Groq (fast, cheap, OpenAI-compatible)
# DECLUTTER_ANALYSIS_PROVIDER=groq
# DECLUTTER_INFERENCE_BASE_URL=https://api.groq.com/openai/v1
# DECLUTTER_INFERENCE_MODEL=llama-3.2-90b-vision-preview
# DECLUTTER_INFERENCE_API_KEY=gsk_...
#
# Example: Anthropic Claude
# DECLUTTER_ANALYSIS_PROVIDER=anthropic
# DECLUTTER_INFERENCE_BASE_URL=https://api.anthropic.com
# DECLUTTER_INFERENCE_MODEL=claude-3-5-sonnet-20241022
# DECLUTTER_INFERENCE_API_KEY=sk-ant-...
#
# Example: LM Studio (local, self-hosted)
# DECLUTTER_ANALYSIS_PROVIDER=lmstudio
# DECLUTTER_INFERENCE_BASE_URL=http://host.docker.internal:1234/v1
# DECLUTTER_INFERENCE_MODEL=replace-with-loaded-vision-model
# DECLUTTER_INFERENCE_TIMEOUT_SECONDS=180
#
# Example: Ollama native API (not OpenAI-compatible wrapper)
# DECLUTTER_ANALYSIS_PROVIDER=ollama-native
# DECLUTTER_INFERENCE_BASE_URL=http://host.docker.internal:11434
# DECLUTTER_INFERENCE_MODEL=llava
# DECLUTTER_INFERENCE_TIMEOUT_SECONDS=180

# Production upgrade auth modes:
# - strict: Firebase Admin SDK verifies ID + App Check tokens. Use for production.
# - scaffold: deterministic local/demo tokens; do not expose publicly.
# - off: local-only bypass; never use on a public deployment.
DECLUTTER_AUTH_MODE=strict
FIREBASE_PROJECT_ID=your-firebase-project-id

# Comma-separated browser origins allowed to call the API.
# Example: https://declutter.example.com,https://app.declutter.example.com
DECLUTTER_CORS_ALLOW_ORIGINS=https://your-launch-domain.example

# Storage. Production readiness expects s3 plus a bucket.
DECLUTTER_STORAGE_BACKEND=s3
DECLUTTER_S3_BUCKET=your-private-upload-bucket
DECLUTTER_S3_PREFIX=intake
AWS_REGION=us-east-1

# Model/provider gate for the current backend scaffold.
# Use your launch provider name; the current service still returns deterministic starter output.
DECLUTTER_MODEL_PROVIDER=launch-model-provider

# eBay API credentials live only on the backend/secret manager.
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret

# Local/demo-only scaffold tokens, required only when DECLUTTER_AUTH_MODE=scaffold.
# DECLUTTER_TEST_ID_TOKEN=replace-with-a-random-demo-token
# DECLUTTER_TEST_APP_CHECK_TOKEN=replace-with-a-random-demo-app-check-token

# Durable Cash-to-Clear session store. Use a persistent volume/path in demo deployments.
DECLUTTER_SESSION_DB_PATH=/data/declutter_ai_sessions.sqlite3

# Local storage fallback when DECLUTTER_STORAGE_BACKEND=local.
# DECLUTTER_UPLOAD_DIR=/tmp/declutter_ai_uploads
