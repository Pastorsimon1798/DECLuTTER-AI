# DECLuTTER-AI backend environment template.
# Copy to .env locally or set these values in your host secret manager.

# Self-hosted MVP mode (recommended first on a VPS):
# DECLUTTER_AUTH_MODE=shared_token
# DECLUTTER_SHARED_ACCESS_TOKEN=replace-with-a-long-random-self-hosted-token
# DECLUTTER_STORAGE_BACKEND=local
# DECLUTTER_UPLOAD_DIR=/data/uploads
# DECLUTTER_SESSION_DB_PATH=/data/declutter_ai_sessions.sqlite3

# Production upgrade auth modes:
# - strict: Firebase Admin SDK verifies ID + App Check tokens. Use for production.
# - scaffold: deterministic local/demo tokens; do not expose publicly.
# - off: local-only bypass; never use on a public deployment.
DECLUTTER_AUTH_MODE=strict
FIREBASE_PROJECT_ID=your-firebase-project-id

# Comma-separated browser origins allowed to call the API.
# Example: https://declutter.example.com,https://app.declutter.example.com
DECLUTTER_CORS_ALLOW_ORIGINS=https://your-launch-domain.example

# Storage. Production readiness expects s3 plus a bucket.
DECLUTTER_STORAGE_BACKEND=s3
DECLUTTER_S3_BUCKET=your-private-upload-bucket
DECLUTTER_S3_PREFIX=intake
AWS_REGION=us-east-1

# Model/provider gate for the current backend scaffold.
# Use your launch provider name; the current service still returns deterministic starter output.
DECLUTTER_MODEL_PROVIDER=launch-model-provider

# eBay API credentials live only on the backend/secret manager.
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret

# Local/demo-only scaffold tokens, required only when DECLUTTER_AUTH_MODE=scaffold.
# DECLUTTER_TEST_ID_TOKEN=replace-with-a-random-demo-token
# DECLUTTER_TEST_APP_CHECK_TOKEN=replace-with-a-random-demo-app-check-token

# Durable Cash-to-Clear session store. Use a persistent volume/path in demo deployments.
DECLUTTER_SESSION_DB_PATH=/data/declutter_ai_sessions.sqlite3

# Local storage fallback when DECLUTTER_STORAGE_BACKEND=local.
# DECLUTTER_UPLOAD_DIR=/tmp/declutter_ai_uploads
