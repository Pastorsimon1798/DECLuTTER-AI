# Copy this file to env.hostinger on the VPS and fill real values there.
# Do not commit env.hostinger.

# Public DNS name that points at the VPS, without scheme.
# Example: api.example.com
DECLUTTER_PUBLIC_HOST=api.your-domain.example

# Self-hosted MVP default: one shared bearer token, local uploads, and SQLite.
# Generate a long random token on the VPS, for example:
#   openssl rand -base64 48
DECLUTTER_AUTH_MODE=shared_token
DECLUTTER_SHARED_ACCESS_TOKEN=replace-with-a-long-random-self-hosted-token
DECLUTTER_CORS_ALLOW_ORIGINS=https://your-launch-frontend.example

# Persistent container paths. The compose file mounts /data as a named volume.
DECLUTTER_STORAGE_BACKEND=local
DECLUTTER_SESSION_DB_PATH=/data/declutter_ai_sessions.sqlite3
DECLUTTER_UPLOAD_DIR=/data/uploads

# Optional home inference server, using the same OpenAI-compatible / LM Studio
# style env pattern as Achiote. If the provider runs on the VPS host, the compose
# file maps host.docker.internal to the host gateway for the API container.
# DECLUTTER_ANALYSIS_PROVIDER=lmstudio
# DECLUTTER_INFERENCE_BASE_URL=http://host.docker.internal:1234/v1
# DECLUTTER_INFERENCE_MODEL=replace-with-loaded-vision-model
# DECLUTTER_INFERENCE_TIMEOUT_SECONDS=180
# DECLUTTER_INFERENCE_API_KEY=

# Later public-production upgrades. These are intentionally not required for
# the self-hosted MVP path.
# FIREBASE_PROJECT_ID=your-firebase-project-id
# DECLUTTER_STORAGE_BACKEND=s3
# DECLUTTER_S3_BUCKET=your-private-upload-bucket
# DECLUTTER_S3_PREFIX=intake
# AWS_REGION=us-east-1
# DECLUTTER_MODEL_PROVIDER=launch-model-provider
# EBAY_CLIENT_ID=your-ebay-client-id
# EBAY_CLIENT_SECRET=your-ebay-client-secret
